<Page x:Class="AutoOS.Views.Settings.PowerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS.Views.Settings.Power"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="SubgroupTemplate">
            <TreeViewItem IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                          ItemsSource="{Binding SubItems}"
                          Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Margin="-24,0,0,0"
                               Text="{Binding Name}" />
                    <TextBlock />
                    <TextBlock />
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <DataTemplate x:Key="SettingTemplate">
            <TreeViewItem Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Text="{Binding Name}" />
                    <TextBlock Text="{Binding AcValueIndex}" />
                    <TextBlock Text="{Binding DcValueIndex}" />
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <local:PowerItemTemplateSelector x:Key="PowerItemTemplateSelector"
                                         SettingTemplate="{StaticResource SettingTemplate}"
                                         SubgroupTemplate="{StaticResource SubgroupTemplate}" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Margin="36,24,36,0">
            <!--  Title  -->
            <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                       Text="Energy &amp; Power" />
            <Grid Margin="0,48,0,12"
                  HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Search  -->
                <dev:TextBox x:Name="Search"
                             Grid.Column="0"
                             Margin="0,0,8,0"
                             IsEnabled="False"
                             PlaceholderText="Search..."
                             TextChanged="SearchBox_TextChanged">
                    <dev:TextBox.Content>
                        <Button Content="&#xE71E;" />
                    </dev:TextBox.Content>
                </dev:TextBox>
                <!--  Powerplan  -->
                <ComboBox x:Name="PowerPlanComboBox"
                          Grid.Column="1"
                          Margin="0,0,8,0"
                          HorizontalAlignment="Stretch"
                          IsEnabled="False"
                          SelectionChanged="PowerPlanComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="local:PowerPlan">
                            <TextBlock Text="{x:Bind Name}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap">
                                <ToolTipService.ToolTip>
                                    <TextBlock Text="{x:Bind Description}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <!--  Edit  -->
                <Button x:Name="Edit"
                        Grid.Column="2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Stretch"
                        Click="Edit_Click"
                        IsEnabled="False">
                    <FontIcon FontSize="14"
                              Glyph="&#xE70F;" />
                </Button>
                <!--  Delete  -->
                <Button x:Name="Delete"
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        VerticalAlignment="Stretch"
                        Click="Delete_Click"
                        IsEnabled="False">
                    <FontIcon FontSize="14"
                              Glyph="&#xE74D;" />
                </Button>
                <!--  Export  -->
                <Button x:Name="Export"
                        Grid.Column="4"
                        Margin="0,0,8,0"
                        Click="Export_Click"
                        IsEnabled="False">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xEDE1;" />
                        <TextBlock Text="Export" />
                    </StackPanel>
                </Button>
                <!--  Import  -->
                <Button x:Name="Import"
                        Grid.Column="5"
                        Click="Import_Click"
                        IsEnabled="False">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xE8B5;" />
                        <TextBlock Text="Import" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
        <dev:SwitchPresenter x:Name="SwitchPresenter"
                             Grid.Row="1"
                             Value="Loading">
            <dev:Case Value="Loading">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical"
                            Spacing="8">
                    <ProgressRing IsActive="True" />
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Fetching Settings..." />
                </StackPanel>
            </dev:Case>
            <dev:Case Value="Loaded">
                <!--  Background  -->
                <Border Grid.Row="1"
                        Margin="36,0,36,36"
                        Padding="4,6"
                        VerticalAlignment="Top"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">
                    <!--  ScrollViewer  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <!--  TreeView  -->
                        <controls:HeaderedTreeView x:Name="PowerTreeView"
                                                   AllowDrop="False"
                                                   CanDrag="False"
                                                   CanDragItems="False"
                                                   ItemInvoked="TreeView_ItemInvoked"
                                                   ItemTemplateSelector="{StaticResource PowerItemTemplateSelector}"
                                                   ItemsSource="{x:Bind Subgroups}"
                                                   SelectionMode="None">
                            <!--  Headers  -->
                            <controls:HeaderedTreeView.Header>
                                <controls:DataTable ColumnSpacing="8">
                                    <controls:DataColumn Content=""
                                                         DesiredWidth="Auto" />
                                    <controls:DataColumn Margin="-48,0,48,0"
                                                         Content="Name"
                                                         DesiredWidth="*" />
                                    <controls:DataColumn MinWidth="75"
                                                         Content="Ac"
                                                         DesiredWidth="75" />
                                    <controls:DataColumn MinWidth="100"
                                                         Content="Dc"
                                                         DesiredWidth="100" />
                                </controls:DataTable>
                            </controls:HeaderedTreeView.Header>
                        </controls:HeaderedTreeView>
                    </ScrollViewer>
                </Border>
            </dev:Case>
        </dev:SwitchPresenter>
    </Grid>
</Page>
