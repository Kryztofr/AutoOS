<Page x:Class="AutoOS.Views.Settings.BiosSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:bios="using:AutoOS.Core.Helpers.BIOS"
      xmlns:common="using:AutoOS.Common"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:data="using:Syncfusion.UI.Xaml.Data"
      xmlns:dev="using:DevWinUI"
      xmlns:grid="using:Syncfusion.UI.Xaml.Grids"
      xmlns:local="using:AutoOS.Views.Settings.BIOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:sfgrid="using:Syncfusion.UI.Xaml.TreeGrid"
      xmlns:views="using:AutoOS.Views"
      mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:StringVisibilityConverter x:Key="StringVisibilityConverter" />

            <!--  Critical  -->
            <Style x:Key="CriticalCellStyle"
                   TargetType="sfgrid:TreeGridCell">
                <Setter Property="Background"
                        Value="{ThemeResource SystemFillColorCriticalBackgroundBrush}" />
            </Style>

            <!--  Success  -->
            <Style x:Key="SuccessCellStyle"
                   TargetType="sfgrid:TreeGridCell">
                <Setter Property="Background"
                        Value="{ThemeResource SystemFillColorSuccessBackgroundBrush}" />
            </Style>

            <!--  Caution  -->
            <Style x:Key="CautionCellStyle"
                   TargetType="sfgrid:TreeGridCell">
                <Setter Property="Background"
                        Value="{ThemeResource SystemFillColorCautionBackgroundBrush}" />
                <Setter Property="BorderThickness"
                        Value="0,0,1,1" />
                <Setter Property="BorderBrush"
                        Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="Padding"
                        Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="sfgrid:TreeGridCell">
                            <Grid x:Name="Root"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="IndicationStates">
                                        <VisualState x:Name="NoError" />
                                        <VisualState x:Name="HasError">
                                            <VisualState.Setters>
                                                <Setter Target="PART_InValidCellBorder.Visibility"
                                                        Value="Visible" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CurrentStates">
                                        <VisualState x:Name="Regular" />
                                        <VisualState x:Name="Current">
                                            <VisualState.Setters>
                                                <Setter Target="PART_CurrentCellBorder.Visibility"
                                                        Value="Visible" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter />
                                <Border x:Name="PART_CurrentCellBorder"
                                        Background="Transparent"
                                        BorderBrush="{TemplateBinding CurrentCellBorderBrush}"
                                        BorderThickness="{TemplateBinding CurrentCellBorderThickness}"
                                        IsHitTestVisible="False"
                                        Visibility="Collapsed" />
                                <Border x:Name="PART_InValidCellBorder"
                                        Width="10"
                                        Height="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Visibility="Collapsed">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Background="{ThemeResource SystemFillColorCaution}"
                                                 Placement="Right"
                                                 Tag="{TemplateBinding ErrorMessage}"
                                                 Template="{StaticResource TreeGridCellCautionToolTipTemplate}" />
                                    </ToolTipService.ToolTip>
                                    <Path Data="M0.5,0.5 L12.652698,0.5 12.652698,12.068006 z"
                                          Fill="{ThemeResource SystemFillColorCautionBrush}"
                                          Stretch="Fill" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Caution Badge  -->
            <ControlTemplate x:Key="TreeGridCellCautionToolTipTemplate">
                <Grid x:Name="PART_ToolTipPresenter"
                      Margin="5,0"
                      Opacity="0"
                      RenderTransformOrigin="0,0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="Transform"
                                            X="-25" />
                    </Grid.RenderTransform>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="OpenStates">
                            <VisualStateGroup.Transitions>
                                <VisualTransition GeneratedDuration="0" />
                                <VisualTransition GeneratedDuration="0:0:0.2"
                                                  To="Opened">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Transform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude=".3"
                                                          EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="PART_ToolTipPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualTransition>
                            </VisualStateGroup.Transitions>
                            <VisualState x:Name="Closed">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="PART_ToolTipPresenter"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0" />
                                </Storyboard>
                            </VisualState>
                            <VisualState x:Name="Opened">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Transform"
                                                     Storyboard.TargetProperty="X"
                                                     To="0"
                                                     Duration="0" />
                                    <DoubleAnimation Storyboard.TargetName="PART_ToolTipPresenter"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0" />
                                </Storyboard>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Border Margin="4,4,-4,-4"
                            Background="Transparent"
                            CornerRadius="5" />
                    <Border Margin="3,3,-3,-3"
                            Background="Transparent"
                            CornerRadius="4" />
                    <Border Margin="2,2,-2,-2"
                            Background="Transparent"
                            CornerRadius="3" />
                    <Border Margin="1,1,-1,-1"
                            Background="Transparent"
                            CornerRadius="2" />
                    <Border Background="{ThemeResource SystemFillColorCaution}"
                            CornerRadius="2" />
                    <Border BorderBrush="{ThemeResource SystemFillColorCaution}"
                            CornerRadius="2">
                        <TextBlock MaxWidth="250"
                                   Margin="8,4,8,4"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   HighContrastAdjustment="None"
                                   Text="{TemplateBinding Tag}"
                                   UseLayoutRounding="false" />
                    </Border>
                </Grid>
            </ControlTemplate>

            <!--  Cell style selector  -->
            <local:CellStyleSelector x:Key="BiosCellStyleSelector"
                                     CautionStyle="{StaticResource CautionCellStyle}"
                                     CriticalStyle="{StaticResource CriticalCellStyle}"
                                     IsDiff="False"
                                     SuccessStyle="{StaticResource SuccessCellStyle}" />

            <!--  Diff grid cell style selector  -->
            <local:CellStyleSelector x:Key="DiffCellStyleSelector"
                                     CautionStyle="{StaticResource CautionCellStyle}"
                                     CriticalStyle="{StaticResource CriticalCellStyle}"
                                     IsDiff="True"
                                     SuccessStyle="{StaticResource SuccessCellStyle}" />

            <!--  ComboBox template  -->
            <DataTemplate x:Key="ComboBoxEditTemplate"
                          x:DataType="local:BiosTreeNode">
                <ComboBox HorizontalAlignment="Stretch"
                          BorderThickness="0"
                          CornerRadius="0"
                          ItemsSource="{x:Bind Options}"
                          Loaded="EditControl_Loaded"
                          SelectedItem="{x:Bind EditOption, Mode=TwoWay}"
                          UseSystemFocusVisuals="False">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackgroundBorderBrushFocused"
                                         Color="Transparent" />
                        <SolidColorBrush x:Key="ComboBoxBackgroundFocused"
                                         Color="{ThemeResource ControlFillColorSecondary}" />
                        <Thickness x:Key="ComboBoxBackgroundBorderThicknessFocused">0</Thickness>
                    </ComboBox.Resources>
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="bios:Option">
                            <TextBlock Padding="0,2,0,0"
                                       FontFamily="Segoe UI Variable Static Text"
                                       Text="{x:Bind Label}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </DataTemplate>

            <!--  TextBox template  -->
            <DataTemplate x:Key="TextBoxEditTemplate"
                          x:DataType="local:BiosTreeNode">
                <TextBox Padding="12,5,6,6"
                         BorderThickness="0"
                         CornerRadius="0"
                         FontFamily="Segoe UI Variable Static Text"
                         Loaded="EditControl_Loaded"
                         Text="{x:Bind EditValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused"
                                         Color="Transparent" />
                        <SolidColorBrush x:Key="TextControlBackgroundFocused"
                                         Color="{ThemeResource ControlFillColorSecondary}" />
                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                    </TextBox.Resources>
                </TextBox>
            </DataTemplate>

            <local:EditTemplateSelector x:Key="EditTemplateSelector"
                                        ComboBoxTemplate="{StaticResource ComboBoxEditTemplate}"
                                        TextBoxTemplate="{StaticResource TextBoxEditTemplate}" />

            <common:TreeGridSortComparer x:Key="DisplayNameComparer"
                                         PropertyName="DisplayName" />
            <common:TreeGridSortComparer x:Key="DisplayCurrentComparer"
                                         PropertyName="DisplayCurrent" />
            <common:TreeGridSortComparer x:Key="DisplayRecommendedComparer"
                                         PropertyName="DisplayRecommended" />
            <common:TreeGridSortComparer x:Key="DisplayDefaultComparer"
                                         PropertyName="DisplayDefault" />
            <common:TreeGridSortComparer x:Key="DisplayOriginalComparer"
                                         PropertyName="DisplayOriginal" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0"
                    Margin="36,24,36,0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                       Text="BIOS Settings" />

            <Grid Margin="0,48,0,8"
                  ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Search  -->
                <dev:TextBox x:Name="Search"
                             Grid.Column="0"
                             IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                             IsSpellCheckEnabled="False"
                             PlaceholderText="Search..."
                             TextChanged="Search_TextChanged"
                             ToolTipService.ToolTip="Search (Ctrl+F)">
                    <dev:TextBox.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F"
                                             Invoked="Search_AcceleratorInvoked"
                                             Modifiers="Control" />
                    </dev:TextBox.KeyboardAccelerators>
                    <dev:TextBox.Content>
                        <Button Content="&#xE71E;" />
                    </dev:TextBox.Content>
                </dev:TextBox>

                <!--  Filter  -->
                <DropDownButton Grid.Column="1"
                                VerticalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                                ToolTipService.ToolTip="Filter (Alt+Shift+F)">
                    <DropDownButton.Content>
                        <FontIcon FontSize="12"
                                  Glyph="&#xE71C;" />
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">

                            <!--  Setting  -->
                            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.FilterSetting, Mode=TwoWay}"
                                                  Text="Setting" />

                            <!--  Description  -->
                            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.FilterDescription, Mode=TwoWay}"
                                                  Text="Description" />

                            <!--  Separator  -->
                            <MenuFlyoutSeparator />

                            <!--  Current  -->
                            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.FilterCurrent, Mode=TwoWay}"
                                                  Text="Current" />

                            <!--  Separator  -->
                            <MenuFlyoutSeparator />

                            <!--  Contains  -->
                            <RadioMenuFlyoutItem GroupName="FilterModeGroup"
                                                 IsChecked="{x:Bind ViewModel.FilterContains, Mode=TwoWay}"
                                                 Text="Contains" />

                            <!--  Exact Match  -->
                            <RadioMenuFlyoutItem GroupName="FilterModeGroup"
                                                 IsChecked="{x:Bind ViewModel.FilterExactMatch, Mode=TwoWay}"
                                                 Text="Exact Match" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                    <DropDownButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F"
                                             Modifiers="Menu, Shift" />
                    </DropDownButton.KeyboardAccelerators>
                </DropDownButton>
            </Grid>

            <!--  Command Bar  -->
            <Border Margin="0,0,0,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}">
                <CommandBar>

                    <!--  Undo  -->
                    <AppBarButton Click="Undo_Click"
                                  Icon="{dev:FontIcon Glyph=&#xE7A7;}"
                                  IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}"
                                  Label="Undo">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Z"
                                                 Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>

                    <!--  Redo  -->
                    <AppBarButton Click="Redo_Click"
                                  Icon="{dev:FontIcon Glyph=&#xE7A6;}"
                                  IsEnabled="{x:Bind ViewModel.CanRedo, Mode=OneWay}"
                                  Label="Redo">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Y"
                                                 Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>

                    <!--  Separator  -->
                    <AppBarSeparator Margin="4,0" />

                    <!--  Merge Count  -->
                    <AppBarElementContainer Style="{StaticResource CommandBarElementContainerStyle}">
                        <NumberBox x:Name="MergeCountBox"
                                   IsEnabled="{x:Bind ViewModel.CanMerge, Mode=OneWay}"
                                   Maximum="{x:Bind ViewModel.RecommendedCount, Mode=OneWay}"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Inline"
                                   ToolTipService.ToolTip="Merge Count"
                                   Value="{x:Bind ViewModel.MergeCount, Mode=TwoWay}" />
                    </AppBarElementContainer>

                    <!--  Merge  -->
                    <AppBarButton Click="Merge_Click"
                                  Icon="{dev:FontIcon Glyph=&#xEA3C;}"
                                  IsEnabled="{x:Bind ViewModel.CanApplyMerge, Mode=OneWay}"
                                  Label="Merge">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="M"
                                                 Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>

                    <!--  Separator  -->
                    <AppBarSeparator Margin="4,0" />

                    <!--  View Changes  -->
                    <AppBarToggleButton x:Name="ViewChanges"
                                        Checked="ViewChanges_Checked"
                                        Icon="{dev:FontIcon Glyph=&#xF28B;}"
                                        IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                                        Label="{x:Bind ViewModel.ViewChangesLabel, Mode=OneWay}"
                                        ToolTipService.ToolTip="View Changes (Ctrl+D)"
                                        Unchecked="ViewChanges_Unchecked">
                        <AppBarToggleButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="D"
                                                 Modifiers="Control" />
                        </AppBarToggleButton.KeyboardAccelerators>
                    </AppBarToggleButton>

                    <!--  Separator  -->
                    <AppBarSeparator Margin="4,0" />

                    <!--  Restore  -->
                    <AppBarButton x:Name="Restore"
                                  Click="Restore_Click"
                                  Icon="{dev:FontIcon Glyph=&#xE81C;}"
                                  IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                                  Label="Restore">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="R"
                                                 Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>

                    <!--  Separator  -->
                    <AppBarSeparator Margin="4,0" />

                    <!--  Import  -->
                    <AppBarButton Click="Import_Click"
                                  Icon="{dev:FontIcon Glyph=&#xE8B5;}"
                                  IsEnabled="{x:Bind ViewModel.CanImport, Mode=OneWay}"
                                  Label="Import to NVRAM">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="I"
                                                 Modifiers="Control" />
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </CommandBar>
            </Border>
        </StackPanel>

        <!--  Switch Presenter  -->
        <dev:SwitchPresenter x:Name="SwitchPresenter"
                             Grid.Row="1"
                             Value="Export">

            <!--  Export  -->
            <dev:Case Value="Export">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <ProgressRing IsActive="True" />
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Exporting NVRAM..." />
                </StackPanel>
            </dev:Case>

            <!--  Import  -->
            <dev:Case Value="Import">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <ProgressRing IsActive="True" />
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Importing NVRAM..." />
                </StackPanel>
            </dev:Case>

            <dev:Case Value="Loaded">
                <Grid Margin="36,0,36,36">

                    <!--  Tree Grid (Main)  -->
                    <sfgrid:SfTreeGrid x:Name="BiosTreeGrid"
                                       AllowEditing="True"
                                       AllowSorting="True"
                                       AllowTriStateSorting="True"
                                       AutoExpandMode="AllNodesExpanded"
                                       AutoGenerateColumns="False"
                                       CellToolTipOpening="BiosTreeGrid_CellToolTipOpening"
                                       ChildPropertyName="Children"
                                       ColumnWidthMode="Star"
                                       CurrentCellBeginEdit="BiosTreeGrid_CurrentCellBeginEdit"
                                       CurrentCellEndEdit="BiosTreeGrid_CurrentCellEndEdit"
                                       DataValidationMode="InView"
                                       EditTrigger="OnTap"
                                       EditorSelectionBehavior="SelectAll"
                                       FilterLevel="All"
                                       GridLinesVisibility="Both"
                                       ItemsSource="{x:Bind ViewModel.TreeNodes}"
                                       Loaded="BiosTreeGrid_Loaded"
                                       NavigationMode="Cell"
                                       NodeCollapsing="BiosTreeGrid_NodeCollapsing"
                                       PasteOption="None"
                                       SelectionMode="Single"
                                       TreeGridContextFlyoutOpening="BiosTreeGrid_TreeGridContextFlyoutOpening"
                                       Visibility="{x:Bind ViewChanges.IsChecked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                        <sfgrid:SfTreeGrid.HeaderContextFlyout>
                            <MenuFlyout />
                        </sfgrid:SfTreeGrid.HeaderContextFlyout>
                        <sfgrid:SfTreeGrid.SortComparers>
                            <data:SortComparer Comparer="{StaticResource DisplayNameComparer}"
                                               PropertyName="DisplayName" />
                            <data:SortComparer Comparer="{StaticResource DisplayCurrentComparer}"
                                               PropertyName="DisplayCurrent" />
                            <data:SortComparer Comparer="{StaticResource DisplayRecommendedComparer}"
                                               PropertyName="DisplayRecommended" />
                            <data:SortComparer Comparer="{StaticResource DisplayDefaultComparer}"
                                               PropertyName="DisplayDefault" />
                        </sfgrid:SfTreeGrid.SortComparers>
                        <sfgrid:SfTreeGrid.Columns>

                            <!--  Setting  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="3"
                                                       AllowFocus="False"
                                                       HeaderText="Setting"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayName"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />

                            <!--  Current  -->
                            <sfgrid:TreeGridTemplateColumn common:StarRatio.ColumnRatio="1"
                                                           AllowSorting="True"
                                                           CellStyleSelector="{StaticResource BiosCellStyleSelector}"
                                                           EditTemplateSelector="{StaticResource EditTemplateSelector}"
                                                           HeaderText="Current"
                                                           MappingName="DisplayCurrent"
                                                           ShowToolTip="True">
                                <sfgrid:TreeGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="local:BiosTreeNode">
                                        <TextBlock Margin="12,0"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind DisplayCurrent, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </DataTemplate>
                                </sfgrid:TreeGridTemplateColumn.CellTemplate>
                            </sfgrid:TreeGridTemplateColumn>

                            <!--  Recommended  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="1"
                                                       AllowFocus="False"
                                                       CellStyleSelector="{StaticResource BiosCellStyleSelector}"
                                                       HeaderText="Recommended"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayRecommended"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />

                            <!--  Default  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="1"
                                                       AllowFocus="False"
                                                       HeaderText="Default"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayDefault"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                        </sfgrid:SfTreeGrid.Columns>
                    </sfgrid:SfTreeGrid>

                    <!--  Tree View (View Changes)  -->
                    <sfgrid:SfTreeGrid x:Name="BiosDiffTreeGrid"
                                       AllowEditing="True"
                                       AllowSorting="True"
                                       AllowTriStateSorting="True"
                                       AutoExpandMode="AllNodesExpanded"
                                       AutoGenerateColumns="False"
                                       CellToolTipOpening="BiosDiffTreeGrid_CellToolTipOpening"
                                       ChildPropertyName="Children"
                                       ColumnWidthMode="Star"
                                       CurrentCellBeginEdit="BiosDiffTreeGrid_CurrentCellBeginEdit"
                                       CurrentCellEndEdit="BiosDiffTreeGrid_CurrentCellEndEdit"
                                       DataValidationMode="InView"
                                       EditTrigger="OnTap"
                                       EditorSelectionBehavior="SelectAll"
                                       FilterLevel="All"
                                       GridLinesVisibility="Both"
                                       ItemsSource="{x:Bind ViewModel.DiffNodes}"
                                       Loaded="BiosDiffTreeGrid_Loaded"
                                       NavigationMode="Cell"
                                       NodeCollapsing="BiosDiffTreeGrid_NodeCollapsing"
                                       PasteOption="None"
                                       SelectionMode="Single"
                                       TreeGridContextFlyoutOpening="BiosDiffTreeGrid_TreeGridContextFlyoutOpening"
                                       Visibility="{x:Bind ViewChanges.IsChecked, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <sfgrid:SfTreeGrid.HeaderContextFlyout>
                            <MenuFlyout />
                        </sfgrid:SfTreeGrid.HeaderContextFlyout>
                        <sfgrid:SfTreeGrid.SortComparers>
                            <data:SortComparer Comparer="{StaticResource DisplayNameComparer}"
                                               PropertyName="DisplayName" />
                            <data:SortComparer Comparer="{StaticResource DisplayOriginalComparer}"
                                               PropertyName="DisplayOriginal" />
                            <data:SortComparer Comparer="{StaticResource DisplayCurrentComparer}"
                                               PropertyName="DisplayCurrent" />
                            <data:SortComparer Comparer="{StaticResource DisplayDefaultComparer}"
                                               PropertyName="DisplayDefault" />
                        </sfgrid:SfTreeGrid.SortComparers>
                        <sfgrid:SfTreeGrid.SortColumnDescriptions>
                            <grid:SortColumnDescription ColumnName="DisplayName"
                                                        SortDirection="Ascending" />
                        </sfgrid:SfTreeGrid.SortColumnDescriptions>
                        <sfgrid:SfTreeGrid.Columns>

                            <!--  Setting  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="3"
                                                       AllowFocus="False"
                                                       HeaderText="Setting"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayName"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />

                            <!--  Original  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="1"
                                                       AllowFocus="False"
                                                       CellStyleSelector="{StaticResource DiffCellStyleSelector}"
                                                       HeaderText="Original"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayOriginal"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />

                            <!--  New  -->
                            <sfgrid:TreeGridTemplateColumn common:StarRatio.ColumnRatio="1"
                                                           AllowSorting="True"
                                                           CellStyleSelector="{StaticResource DiffCellStyleSelector}"
                                                           EditTemplateSelector="{StaticResource EditTemplateSelector}"
                                                           HeaderText="New"
                                                           MappingName="DisplayCurrent"
                                                           ShowToolTip="True">
                                <sfgrid:TreeGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="local:BiosTreeNode">
                                        <TextBlock Margin="12,0"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind DisplayCurrent, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </DataTemplate>
                                </sfgrid:TreeGridTemplateColumn.CellTemplate>
                            </sfgrid:TreeGridTemplateColumn>

                            <!--  Default  -->
                            <sfgrid:TreeGridTextColumn common:StarRatio.ColumnRatio="1"
                                                       AllowFocus="False"
                                                       HeaderText="Default"
                                                       IsReadOnly="True"
                                                       MappingName="DisplayDefault"
                                                       ShowToolTip="True"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                        </sfgrid:SfTreeGrid.Columns>
                    </sfgrid:SfTreeGrid>
                </Grid>
            </dev:Case>

            <!--  Unsupported  -->
            <dev:Case Value="Unsupported">
                <StackPanel Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <FontIcon HorizontalAlignment="Center"
                              FontSize="32"
