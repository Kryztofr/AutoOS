<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Settings.InternetPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:converters="using:CommunityToolkit.WinUI.Converters"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:dev="using:DevWinUI"
	  xmlns:local="using:AutoOS"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:models="using:AutoOS.Core.Helpers.Device.Models"
	  xmlns:net="using:AutoOS.Core.Helpers.Network"
	  xmlns:views="using:AutoOS.Views"
	  mc:Ignorable="d">
	<Page.Resources>
		<converters:BoolToObjectConverter x:Key="BoolToObjectConverter"
										  FalseValue="&#xE839;"
										  TrueValue="&#xE701;" />
	</Page.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<TextBlock Margin="36,24,0,0"
				   Style="{StaticResource TitleTextBlockStyle}"
				   Text="Network &amp; Internet" />
		<ScrollViewer Grid.Row="1"
					  VerticalScrollBarVisibility="Auto"
					  VerticalScrollMode="Auto">
			<StackPanel Margin="{ThemeResource ContentPageMargin}"
						Padding="{ThemeResource ContentPagePadding}">
				<ItemsRepeater x:Name="AdapterRepeater"
							   Margin="0,0,0,28"
							   ItemsSource="{x:Bind NetworkAdapters, Mode=OneWay}">
					<ItemsRepeater.ItemTemplate>
						<DataTemplate x:DataType="models:DeviceInfo">
							<StackPanel>
								<dev:SettingsGroup DataContext="{x:Bind}"
												   Header="{x:Bind FriendlyName, Mode=OneWay}"
												   Loaded="SettingsGroup_Loaded">
									<dev:SettingsGroup.HeaderIcon>
										<FontIcon Foreground="{ThemeResource SystemAccentColor}"
												  Glyph="{x:Bind IsWiFi, Mode=OneWay, Converter={StaticResource BoolToObjectConverter}}" />
									</dev:SettingsGroup.HeaderIcon>
									<dev:SettingsGroup.Content>
										<dev:ProgressButton x:Name="Optimize"
															HorizontalAlignment="Left"
															Checked="Optimize_Checked"
															CheckedContent="Optimizing Adapter..."
															Content="Optimize Adapter"
															IsIndeterminate="True"
															Style="{ThemeResource AccentProgressButtonStyle}" />

									</dev:SettingsGroup.Content>
								</dev:SettingsGroup>
								<StackPanel x:Name="AdapterInfo"
											Margin="4,8,4,0" />
							</StackPanel>
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>
