<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Installer.HomeLandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <dev:MainLandingPage HeaderImage="{ThemeResource HeaderCover}"
                         HeaderImageHeight="400"
                         HeaderSubtitleText="Windows App SDK 2.0"
                         HeaderText="AutoOS Installer"
                         JsonNavigationService="{x:Bind local:App.Current.NavService}">
        <dev:MainLandingPage.HeaderContent>
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <dev:HeaderTile Title="AutoOS User Guide"
                                Description="Instructions on how to get the most out of AutoOS."
                                Link="https://github.com/tinodin/AutoOS/blob/master/docs/INSTALLER_USER_GUIDE.md">
                    <dev:HeaderTile.Source>
                        <Image Source="/Assets/AppIcon.png" />
                    </dev:HeaderTile.Source>
                </dev:HeaderTile>
                <dev:HeaderTile Title="AutoOS Contribution Guide"
                                Description="Contribute to become a part of the AutoOS project."
                                Link="https://github.com/tinodin/AutoOS/blob/master/docs/CONTRIBUTING.md">
                    <dev:HeaderTile.Source>
                        <Viewbox>
                            <PathIcon Data="{StaticResource GitHubIconPath}"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Viewbox>
                    </dev:HeaderTile.Source>
                </dev:HeaderTile>
                <dev:HeaderTile Title="AutoOS Discord Server"
                                Description="Join the community to report issues, get support or suggest new features."
                                Link="https://discord.gg/bZU4dMMWpg">
                    <dev:HeaderTile.Source>
                        <Image Source="/Assets/Fluent/Discord.png" />
                    </dev:HeaderTile.Source>
                </dev:HeaderTile>
                <dev:HeaderTile Title="Donate"
                                Description="Donate if you appreciate the time and effort I put into this project."
                                Link="https://www.paypal.com/donate?hosted_button_id=W3YRLW35QEZWS">
                    <dev:HeaderTile.Source>
                        <Image Source="/Assets/Fluent/PayPal.png" />
                    </dev:HeaderTile.Source>
                </dev:HeaderTile>
            </StackPanel>
        </dev:MainLandingPage.HeaderContent>
        <dev:MainLandingPage.FooterContent>
            <StackPanel />
        </dev:MainLandingPage.FooterContent>
    </dev:MainLandingPage>
</Page>
